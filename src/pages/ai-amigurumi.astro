---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="AIあみぐるみ作家 | SmallTools Lab"
  description="写真をアップロードするだけで、AIが可愛いあみぐるみのデザインと編み図（レシピ）を自動生成。初心者でも編める詳細なレシピ付き。"
>
  <Header />

  <main class="bg-gray-50">
    <!-- アプリ紹介ヘッダー -->
    <div class="bg-swell-navy text-white py-10 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <span class="text-4xl mb-4 block">🧸</span>
        <h1 class="text-2xl md:text-3xl font-bold mb-3">AIあみぐるみ作家</h1>
        <p class="text-sm opacity-80 max-w-2xl mx-auto">
          写真から、あなただけのあみぐるみレシピを。AIがデザインと編み図を自動生成します。
        </p>
      </div>
    </div>

    <!-- iFrame埋め込み -->
    <div class="max-w-6xl mx-auto px-4 py-8">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <iframe
          src="https://ai-amigurumi-app-humwd4os764ngpkomazvtk.streamlit.app/?embed=true"
          class="w-full border-0"
          style="height: 800px;"
          title="AIあみぐるみ作家"
          loading="lazy"
          allow="camera;microphone"
        ></iframe>
      </div>

      <!-- フォールバック: iFrameが表示されない場合 -->
      <p class="text-center text-sm text-gray-500 mt-4">
        アプリが表示されない場合は
        <a
          href="https://ai-amigurumi-app-humwd4os764ngpkomazvtk.streamlit.app/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-swell-blue hover:underline"
        >
          こちらから直接開けます →
        </a>
      </p>
    </div>
  </main>

  <Footer />
</Layout>
