---
export interface Props {
  title: string;
  description: string;
  icon: string;
  noteUrl?: string;
  aboutText?: string;
  steps?: string[];
  appUrl?: string;
}

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
  title,
  description,
  icon,
  noteUrl,
  aboutText,
  steps = [],
  appUrl,
} = Astro.props;
---

<Layout
  title={`${title} | SmallTools Lab`}
  description={description}
>
  <Header />

  <main class="bg-gray-50">
    <!-- アプリ紹介ヘッダー -->
    <div class="bg-swell-navy text-white py-10 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <span class="text-4xl mb-4 block">{icon}</span>
        <h1 class="text-2xl md:text-3xl font-bold mb-3">{title}</h1>
        <p class="text-sm opacity-80 max-w-2xl mx-auto">
          {description}
        </p>
      </div>
    </div>

    <!-- ツール本体エリア -->
    <div class="max-w-6xl mx-auto px-4 py-8">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <slot />
      </div>

      <!-- フォールバック -->
      {appUrl && (
        <p class="text-center text-sm text-gray-500 mt-4">
          アプリが表示されない場合は
          <a
            href={appUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-swell-blue hover:underline"
          >
            こちらから直接開けます →
          </a>
        </p>
      )}
    </div>

    <!-- AdSense Placeholder: ツール直下 -->
    <!-- <div class="max-w-4xl mx-auto px-6 py-4"><ins class="adsbygoogle" data-ad-slot="XXXXXXXXXX"></ins></div> -->

    <!-- 解説記事エリア -->
    <div class="max-w-3xl mx-auto px-6 pb-16">

      <!-- このツールについて -->
      {(aboutText || noteUrl) && (
        <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 mb-8">
          <h2 class="text-xl font-bold text-gray-800 mb-4 border-l-4 border-swell-blue pl-3">
            このツールについて
          </h2>
          {aboutText && (
            <p class="text-sm text-gray-700 leading-relaxed mb-4">
              {aboutText}
            </p>
          )}
          {noteUrl && (
            <a
              href={noteUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-swell-blue hover:underline font-medium"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              開発の背景をnoteで読む →
            </a>
          )}
        </section>
      )}

      <!-- 使い方・活用ステップ -->
      {steps.length > 0 && (
        <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
          <h2 class="text-xl font-bold text-gray-800 mb-6 border-l-4 border-swell-blue pl-3">
            使い方・活用ステップ
          </h2>
          <ol class="space-y-4">
            {steps.map((step, index) => (
              <li class="flex gap-4 items-start">
                <span class="flex-shrink-0 w-8 h-8 bg-swell-blue text-white rounded-full flex items-center justify-center text-sm font-bold">
                  {index + 1}
                </span>
                <p class="text-sm text-gray-700 leading-relaxed pt-1">
                  {step}
                </p>
              </li>
            ))}
          </ol>
        </section>
      )}

    </div>

    <!-- AdSense Placeholder: 記事最後 -->
    <!-- <div class="max-w-4xl mx-auto px-6 py-4"><ins class="adsbygoogle" data-ad-slot="XXXXXXXXXX"></ins></div> -->

  </main>

  <Footer />
</Layout>
